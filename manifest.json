{
  "manifest_version": 3,
  "name": "Grok Blocker",
  "version": "1.0",
  "description": "Blocks custom phrase posts on X and counts them",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
