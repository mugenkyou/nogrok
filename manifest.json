{
  "manifest_version": 3,
  "name": "Grok Blocker",
  "version": "1.1",
  "description": "Block annoying Grok plan posts on X & count them",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
