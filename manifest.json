{
  "manifest_version": 3,
  "name": "Grok Blocker",
  "version": "1.0",
  "description": "Blocks annoying 'hey grok make a plan' posts on X and shows how many you've blocked.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.x.com/*",
        "*://*.twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
